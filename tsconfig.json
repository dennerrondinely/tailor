{
  "compilerOptions": {
    "target": "ES2018",
    "module": "ESNext",
    "lib": ["dom", "dom.iterable", "esnext"],
    "declaration": true,
    "declarationMap": true,
    "outDir": "./dist",
    "strict": true,
    "jsx": "react-jsx",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "moduleResolution": "Bundler",
    "resolveJsonModule": true,
    "types": ["@testing-library/jest-dom", "jest"]
  },
  "include": ["src"],
  "exclude": [
    "node_modules",
    "dist",
    "src/helpers/__tests__",
    "src/core/utils/__tests__"
  ]
}
